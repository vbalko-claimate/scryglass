# Scryglass environment variables
# Copy this file to .env and fill in values as needed.
# All variables are optional — the app works without any API keys.

# User data directory (decks, strategies, collection)
# SCRY_USER_DATA=~/MTG/mtg-data

# Claude API key (optional — only if using Anthropic API backend)
# ANTHROPIC_API_KEY=sk-ant-...

# Advice mode: hybrid (default), llm_first, llm_only
# SCRY_ADVICE_MODE=hybrid

# Ollama (auto-detected at localhost:11434 if running)
# SCRY_OLLAMA_BASE_URL=http://localhost:11434
# SCRY_OLLAMA_MODEL=llama3.1:8b
