{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Scryglass",
  "version": "0.1.0",
  "identifier": "com.scryglass.app",
  "build": {
    "frontendDist": "http://localhost:8765",
    "devUrl": "http://localhost:8765"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Scryglass — MTGA Advisor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "url": "http://localhost:8765"
      },
      {
        "label": "overlay",
        "title": "",
        "width": 280,
        "height": 200,
        "x": 8,
        "y": 120,
        "transparent": true,
        "decorations": false,
        "alwaysOnTop": true,
        "skipTaskbar": true,
        "resizable": false,
        "url": "http://localhost:8765/overlay",
        "visible": false
      }
    ],
    "trayIcon": {
      "iconPath": "icons/icon.png",
      "iconAsTemplate": true,
      "tooltip": "Scryglass"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/scry-server"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    }
  }
}
