{
  "$schema": "https://raw.githubusercontent.com/tauri-apps/tauri/dev/crates/tauri-config-schema/schema.json",
  "productName": "Scryglass",
  "version": "0.1.0",
  "identifier": "com.scryglass.app",
  "build": {
    "frontendDist": "http://localhost:8765",
    "devUrl": "http://localhost:8765"
  },
  "app": {
    "withGlobalTauri": true,
    "macOSPrivateApi": true,
    "windows": [
      {
        "label": "main",
        "title": "Scryglass — MTGA Advisor",
        "width": 1200,
        "height": 800,
        "minWidth": 800,
        "minHeight": 600,
        "url": "http://localhost:8765"
      }
    ],
    "trayIcon": {
      "iconPath": "icons/tray-icon.png",
      "iconAsTemplate": true,
      "tooltip": "Scryglass"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "macOS": {
      "signing": false
    },
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ],
    "externalBin": [
      "binaries/scry-server"
    ]
  },
  "plugins": {
    "shell": {
      "open": true
    },
    "updater": {
      "endpoints": [
        "https://github.com/vbalko-claimate/scryglass/releases/latest/download/latest.json"
      ],
      "pubkey": "dW50cnVzdGVkIGNvbW1lbnQ6IG1pbmlzaWduIHB1YmxpYyBrZXk6IEQ4M0FBREUyQkVCRTk5NwpSV1NYNmVzcjNxcUREYWhmZ3c4V1JVaytrQW1OWlhsbGpuYUI4M1hpNW5jUmZsMjdGdlhiTC9SZwo="
    }
  }
}
